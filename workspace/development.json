{
    "folders": [
        {
            "path": "/mnt/reference",
            "name": "Odoo source (reference)"
        },
        {
            "path": "/mnt/upgrade/upgrade-util",
            "name": "Upgrade util"
        },
        {
            "path": "/mnt/extra-addons",
            "name": "Custom Developments"
        }
    ],
    "settings": {
        "python.analysis.extraPaths": [
            "/mnt/reference/odoo",
            "/mnt/reference/enterprise",
            "/mnt/reference/design-themes",
            "/mnt/upgrade/upgrade-util/src",
            "/mnt/extra-addons"
        ],
        "files.exclude": {
            "**/*.pyc": true,
            "**/__pycache__": true
        }
    },
    "launch": {
        "version": "0.2.0",
        "configurations": [
            {
                "name": "Docker: Odoo Debug",
                "type": "debugpy",
                "request": "attach",
                "connect": {
                    "host": "localhost",
                    "port": 5678
                },
                "justMyCode": false
            }
        ]
    }
}
