{
    "folders": [
        {
            "path": "/opt/odoo-src",
            "name": "1. Odoo target version"
        },
        {
            "path": "/mnt/reference",
            "name": "2. Odoo source version (For reference only)"
        },
        {
            "path": "/mnt/upgrade",
            "name": "3. Upgrade tools"
        },
        {
            "path": "/mnt/extra-addons",
            "name": "4. Custom Developments"
        }
    ],
    "settings": {
        "python.analysis.extraPaths": [
            "/opt/odoo-src/odoo",
            "/opt/odoo-src/enterprise",
            "/opt/odoo-src/design-themes",
            "/mnt/extra-addons",
            "/mnt/upgrade"
        ],
        "files.exclude": {
            "**/*.pyc": true,
            "**/__pycache__": true
        }
    },
    "launch": {
        "version": "0.2.0",
        "configurations": [
            {
                "name": "Docker: Odoo Debug",
                "type": "debugpy",
                "request": "attach",
                "connect": {
                    "host": "localhost",
                    "port": 5678
                },
                "justMyCode": false
            }
        ]
    }
}
