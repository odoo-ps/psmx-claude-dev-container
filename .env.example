# ==========================================
# DEV ENVIRONMENT FOR: <Customer's_name>
# ==========================================
# Copy this file to .env and fill in the values.

# Odoo source version (the version you're upgrading FROM, e.g. 17.0)
ODOO_SOURCE_VERSION=<source_version>

# Odoo target version (the version you're upgrading TO, e.g. 18.0)
ODOO_TARGET_VERSION=<target_version>

# Absolute path to your local Odoo worktrees (e.g. ~/Odoo/Worktrees)
ODOO_WORKTREE_PATH=~/Odoo/Worktrees

# Absolute path to the Odoo upgrade tools (e.g. ~/Odoo/Upgrade)
ODOO_UPGRADE_PATH=~/Odoo/Upgrade

# Docker Compose project name — used as prefix for container names
COMPOSE_PROJECT_NAME=<customer_name>

# Absolute path to the customer's custom modules repo (e.g. ~/Odoo/Repos/acme-addons)
# The repo lives outside this folder — see ~/Odoo/Repos/
CUSTOMER_REPO=~/Odoo/Repos/<customer_repo_folder>

# Absolute path to the folder where DB dumps are stored locally (e.g. ~/Odoo/Dumps)
DUMPS_PATH=~/Odoo/Dumps

# Name of the database to work with
ODOO_DB_NAME=<database_name>

# Enable remote debugger on port 5678 — set to false to start without debugpy overhead
ODOO_DEBUG=true

# Extra arguments passed to odoo-bin (e.g. -i base for a clean database, --dev=all for hot reload)
ODOO_EXTRA_ARGS=
