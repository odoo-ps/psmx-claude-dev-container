# ==========================================
# DEV ENVIRONMENT FOR: <Customer's_name>
# ==========================================
# Copy this file to .env and fill in the values.

# Operating mode: 'development' (single version) or 'upgrade' (two versions)
ODOO_MODE=development

# --- Development mode --------------------------------------------------
# Odoo version to work with (e.g. 17.0)
ODOO_VERSION=<version>

# --- Upgrade mode ------------------------------------------------------
# Odoo source version (the version you're upgrading FROM, e.g. 17.0)
ODOO_SOURCE_VERSION=
# Odoo target version (the version you're upgrading TO, e.g. 18.0)
ODOO_TARGET_VERSION=

# --- Shared ------------------------------------------------------------
# Docker Compose project name — used as prefix for container names
COMPOSE_PROJECT_NAME=<customer_name>

# Absolute path to the customer's custom modules repo (e.g. ~/Odoo/Repos/acme-addons)
CUSTOMER_REPO=~/Odoo/Repos/<customer_repo_folder>

# Ports exposed to the host — change if running multiple clients simultaneously
ODOO_PORT=8069
ODOO_DEBUG_PORT=5678
# PGADMIN_PORT=5050

# Name of the database to work with
ODOO_DB_NAME=<database_name>

# Enable remote debugger on port 5678 — set to false to start without debugpy overhead
ODOO_DEBUG=true

# Extra arguments always passed to odoo-bin (e.g. --dev=all for hot reload)
ODOO_EXTRA_ARGS=
